{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Form Factory items",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "title", "items"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 1 },
    "sourceNotes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string", "minLength": 1 }
      }
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "gender", "number"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "gender": { "enum": ["masculine", "feminine"] },
          "number": { "enum": ["singular", "plural"] },
          "extension": { "type": "boolean" }
        }
      }
    },
    "items": { "$ref": "#/definitions/itemList" },
    "extensionItems": { "$ref": "#/definitions/itemList" }
  },
  "definitions": {
    "itemList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "level",
          "lemma",
          "translation",
          "reflexive",
          "stemHint",
          "subject",
          "answer",
          "distractors",
          "example",
          "explanation"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "level": { "type": "integer", "minimum": 1 },
          "lemma": { "type": "string", "minLength": 1 },
          "translation": { "type": "string", "minLength": 1 },
          "reflexive": { "type": "boolean" },
          "stemHint": { "type": "string", "minLength": 1 },
          "subject": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "distractors": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 3
          },
          "example": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
